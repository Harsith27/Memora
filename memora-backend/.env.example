# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/memora

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed frontend origins (recommended for production)
# Example: FRONTEND_URLS=https://your-app.vercel.app,https://your-custom-domain.com
FRONTEND_URLS=
# Allow Vercel preview URLs (*.vercel.app) in addition to explicit FRONTEND_URL(S)
ALLOW_VERCEL_PREVIEWS=true
# Optional: keep localhost origins allowed even in production (normally false)
ALLOW_LOCALHOST_CORS=false
BACKEND_PUBLIC_URL=http://localhost:3001

# Production notes
# NODE_ENV=production
# FRONTEND_URLS=https://<your-vercel-domain>.vercel.app,https://<your-custom-domain>
# BACKEND_PUBLIC_URL=https://<your-backend-app>.azurewebsites.net

# File Storage Configuration
# local = store under memora-backend/uploads, azure = store in Azure Blob
FILE_STORAGE_PROVIDER=local

# Azure Blob Storage (required when FILE_STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=uploads

# AI Configuration
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Groq (recommended for student free tier)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Grok (xAI, optional)
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1

# Security
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
# Enable rate limit in non-production environments if needed
ENABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
